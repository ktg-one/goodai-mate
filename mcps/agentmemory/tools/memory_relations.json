{
  "name": "memory_relations",
  "description": "Query the memory relationship graph.",
  "inputSchema": {
    "properties": {
      "maxHops": {
        "description": "Max traversal depth (default 2)",
        "type": "number"
      },
      "memoryId": {
        "description": "Memory ID to find relations for",
        "type": "string"
      },
      "minConfidence": {
        "description": "Min confidence (0-1, default 0)",
        "type": "number"
      }
    },
    "required": [
      "memoryId"
    ],
    "type": "object"
  }
}