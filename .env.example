# Good'ai Environment Variables Template
# Copy this file to .env and fill in the values for local development
# Or set these variables in your deployment platform (Vercel / Railway)

# 1. LLM / AI Gateway Configuration
# The API key for your AI gateway provider (e.g. Gemini, Groq, Claude gateway)
AI_GATEWAY_API_KEY=""

# 2. Text-to-Speech (ElevenLabs) Configuration
# ElevenLabs API Key for voice generation
ELEVEN_API_KEY=""
# Default Voice ID to use for the TTS agent (e.g., Darl/Robokev)
ELEVEN_DEFAULT_VOICE=""

# 3. Google Workspace CLI Integration
# Path to the Google Workspace CLI executable.
# In production / serverless environments (Vercel/Railway), set this if you have a custom path
# or leave blank to let it fall back to node_modules or system commands.
GWS_CLI_PATH=""
# URL for the GWS spreadsheet script (if custom script endpoint is used)
NEXT_PUBLIC_GWS_SCRIPT_URL=""

# 4. n8n Integrations
# Webhook URL triggered for Outbound Callbacks
N8N_CALL_WEBHOOK_URL=""
# Webhook URL triggered for Workspace Playground automation pipeline demo
N8N_DEMO_WEBHOOK_URL=""

# 5. Local/Remote ASR (Speech-to-Text) Service
# Hosted Supertonic / Whisper / ASR endpoint (e.g., http://your-asr-service.railway.app/transcribe)
# Defaults to http://localhost:8000/transcribe if empty during development.
NEXT_PUBLIC_ASR_URL=""
